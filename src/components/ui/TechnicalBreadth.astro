---
// src/components/sections/TechnicalBreadth.astro
import Section from "@layouts/Section.astro";
---

<Section id="scope" class="py-24 border-t border-(--border-subtle)/30">
  <div class="max-w-5xl mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 items-center">

      <div class="md:col-span-5 space-y-6">
        <h3 class="text-xs font-mono uppercase tracking-[0.3em] text-(--accent-primary) font-bold">
          Alcance Técnico / 04
        </h3>
        <h4 class="text-3xl md:text-4xl font-bold tracking-tighter leading-tight">
          Más allá del <br/> desarrollo de código.
        </h4>
        <p class="text-(--text-secondary) font-light leading-relaxed">
          Entiendo el software como un ciclo completo. Mi valor reside en conectar el diseño visual con la arquitectura técnica y la optimización final.
        </p>

        <ul class="space-y-4 pt-4 font-mono text-[10px] uppercase tracking-widest text-(--text-muted)">
          <li class="flex items-center gap-3">
            <span class="size-1 bg-(--accent-primary) rounded-full"></span>
            Arquitectura Escalable
          </li>
          <li class="flex items-center gap-3">
            <span class="size-1 bg-(--accent-primary) rounded-full"></span>
            Diseño de Interfaces (UI)
          </li>
          <li class="flex items-center gap-3">
            <span class="size-1 bg-(--accent-primary) rounded-full"></span>
            Optimización de Rendimiento
          </li>
        </ul>
      </div>

      <div class="md:col-span-7 relative aspect-square flex items-center justify-center p-8">
        <div class="absolute inset-0 flex items-center justify-center pointer-events-none opacity-20">
          <div class="absolute size-full rounded-full border border-(--border-subtle)"></div>
          <div class="absolute size-[70%] rounded-full border border-(--border-subtle)"></div>
          <div class="absolute size-[40%] rounded-full border border-(--border-subtle)"></div>
        </div>

        <div class="relative size-full">
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 z-10">
            <div class="size-16 rounded-full bg-(--bg-main) border-2 border-(--accent-primary) flex items-center justify-center shadow-[0_0_30px_rgba(var(--accent-primary-rgb),0.2)]">
               <span class="text-[10px] font-bold">CORE</span>
            </div>
          </div>

          <div class="absolute top-0 left-1/2 -translate-x-1/2 text-center group">
            <div class="px-3 py-1 border border-(--border-subtle) rounded-full text-[9px] font-mono bg-(--bg-card) group-hover:border-(--accent-primary) transition-colors">DISEÑO UX</div>
            <div class="h-12 w-px bg-gradient-to-t from-(--accent-primary) to-transparent mx-auto mt-2"></div>
          </div>

          <div class="absolute bottom-0 left-1/2 -translate-x-1/2 text-center group">
            <div class="h-12 w-px bg-gradient-to-b from-(--accent-primary) to-transparent mx-auto mb-2"></div>
            <div class="px-3 py-1 border border-(--border-subtle) rounded-full text-[9px] font-mono bg-(--bg-card) group-hover:border-(--accent-primary) transition-colors">DEPLOYS</div>
          </div>

          <div class="absolute left-0 top-1/2 -translate-y-1/2 flex items-center group">
            <div class="px-3 py-1 border border-(--border-subtle) rounded-full text-[9px] font-mono bg-(--bg-card) group-hover:border-(--accent-primary) transition-colors">FRONTEND</div>
            <div class="w-12 h-px bg-gradient-to-l from-(--accent-primary) to-transparent ml-2"></div>
          </div>

          <div class="absolute right-0 top-1/2 -translate-y-1/2 flex items-center group">
            <div class="w-12 h-px bg-gradient-to-r from-(--accent-primary) to-transparent mr-2"></div>
            <div class="px-3 py-1 border border-(--border-subtle) rounded-full text-[9px] font-mono bg-(--bg-card) group-hover:border-(--accent-primary) transition-colors">PERFORMANCE</div>
          </div>
        </div>
      </div>

    </div>
  </div>
</Section>
