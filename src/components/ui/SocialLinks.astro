---
import type { SocialProfile } from "@lib/types/social-profile";
import CopyButton from "./CopyButton.astro";

interface Props {
  profiles: SocialProfile[];
}

const { profiles } = Astro.props;
---

<ul class="flex flex-wrap items-center justify-center lg:justify-start gap-3 w-full">
  <li>
    <CopyButton
      label="enrique.sfranco04@gmail.com"
      text="enrique.sfranco04@gmail.com"
    />
  </li>

  {
    profiles.map(({ network, url }) => (
      <li>
        <a
          href={url}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`Logo de ${network}`}
          title={`Ir a ${network}`}
          class="group inline-flex items-center gap-2.5 px-4 py-2 rounded-full border border-(--border-subtle) bg-(--bg-card) text-[11px] font-mono uppercase tracking-widest text-(--text-muted) hover:border-(--accent-primary) hover:text-(--text-primary) hover:bg-(--bg-main) transition-all duration-300 backdrop-blur-md shadow-sm"
        >
          <svg width="16" height="16" class="opacity-70 group-hover:opacity-100 transition-opacity">
            <use xlink:href={`sprite.svg#${network}`} />
          </svg>
          <span class="hidden sm:inline-block">{network}</span>
        </a>
      </li>
    ))
  }
</ul>
