---
interface Props {
  text: string;
  label?: string;
  copiedLabel?: string;
  iconName?: string;
  variant?: "default" | "ghost" | "outline" | "subtle";
}

const {
  text,
  label = "Copiar",
  copiedLabel = "¡Copiado!",
  iconName = "copy",
  variant = "default"
} = Astro.props;

const variants = {
  default:
    "border border-(--border-subtle) bg-(--bg-card) shadow-sm hover:border-(--accent-primary)",
  ghost:
    "border border-transparent bg-transparent hover:border-(--border-subtle)",
  outline:
    "border border-(--text-muted)/40 bg-transparent hover:border-(--accent-primary)",
  subtle:
    "border border-transparent bg-(--bg-card)/40 hover:bg-(--bg-card)",
};

const variantClass = variants[variant];
---

<button
  id="copy-btn"
  aria-live="polite"
  data-copy-text={text}
  data-copied-label={copiedLabel}
  class={`copy-button group relative flex items-center gap-2.5 px-4 py-2 rounded-full border border-(--border-subtle) bg-(--bg-card) text-[11px] font-mono uppercase tracking-widest text-(--text-muted) transition-all duration-300 hover:border-(--accent-primary) hover:text-(--text-primary) shadow-sm ${variantClass}`}
>
  <span class="copy-tooltip absolute -top-8 left-1/2 -translate-x-1/2 bg-(--text-primary) text-(--bg-main) px-2 py-1 rounded text-[9px] font-bold opacity-0 pointer-events-none transition-all duration-300">
    {copiedLabel}
  </span>

  <svg width="16" height="16">
    <use xlink:href={`sprite.svg#${iconName}`} />
  </svg>

  <span class="max-w-36 truncate sm:max-w-none">
    {label}
  </span>
</button>

<script>
  function setupCopyButtons() {
    const buttons = document.querySelectorAll<HTMLButtonElement>(".copy-button");

    buttons.forEach((button) => {
      if ((button as any).__initialized) return;
      (button as any).__initialized = true;

      const textToCopy = button.dataset.copyText || "";
      const tooltip = button.querySelector(".copy-tooltip");

      button.addEventListener("click", async () => {
        try {
          await navigator.clipboard.writeText(textToCopy);

          if (tooltip) {
            tooltip.classList.add("is-visible");
            button.classList.add("border-(--accent-primary)");

            setTimeout(() => {
              tooltip.classList.remove("is-visible");
              button.classList.remove("border-(--accent-primary)");
            }, 2000);
          }
        } catch (err) {
          console.error("Error al copiar", err);
        }
      });
    });
  }

  setupCopyButtons();
  document.addEventListener("astro:after-swap", setupCopyButtons);
</script>


<style>
  .copy-tooltip.is-visible {
    opacity: 1;
    transform: translate(-50%, -5px);
  }
</style>
