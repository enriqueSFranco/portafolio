---
import { slugify } from "@lib/utils";
import type { CollectionEntry } from "astro:content";

interface Props {
  project: CollectionEntry<"projects">;
  index: number;
}

const { project, index } = Astro.props;
const { title, github, cover, summary, stack, type, status, period } = project.data;

const isEven = index % 2 === 0;
const padded = String(index + 1).padStart(2, "0");
---

<article
  class:list={["project-row group grid grid-cols-1 md:grid-cols-12 md:gap-12 py-16 items-center", { "reveal": true }]}
  style={`--delay: ${index * 100}ms`}
>

  <div class="hidden md:flex md:col-span-1 justify-end items-start pt-2">
    <span class="text-[10px] font-mono text-(--text-muted)/30 tabular-nums">{padded}</span>
  </div>

  <div class:list={["md:col-span-5", isEven ? "md:order-2" : "md:order-3"]}>
    <div class="relative aspect-[16/10] overflow-hidden bg-(--bg-card) image-wrap">
      {cover ? (
        <img
          transition:name={`img-${title}`}
          src={cover}
          alt={title}
          class="h-full w-full object-cover project-img"
          loading="lazy"
        />
      ) : (
        <div class="grid h-full place-content-center border border-(--border-subtle)">
          <span class="text-[10px] font-mono uppercase tracking-widest text-(--text-muted)/40">
            No. {padded}
          </span>
        </div>
      )}

      {status && (
        <div class="absolute top-3 left-3 bg-(--bg-main)/80 backdrop-blur-sm border border-(--border-subtle) px-3 py-1">
          <span class="text-[9px] font-mono uppercase tracking-widest text-(--text-muted)">{status}</span>
        </div>
      )}

      <div class="absolute inset-0 bg-(--bg-main)/70 backdrop-blur-[2px] opacity-0 group-hover:opacity-100 transition-all duration-500 flex items-center justify-center gap-3">
        <a
          href={`/portafolio/projects/${slugify(title)}`}
          class="border border-(--text-primary) text-(--text-primary) px-5 py-2 text-[10px] font-mono font-bold uppercase tracking-[0.2em] hover:bg-(--text-primary) hover:text-(--bg-main) transition-all duration-300"
        >
          Caso de estudio
        </a>
        {github && (
          <a
            href={github}
            target="_blank"
            rel="noopener"
            class="border border-(--border-subtle) text-(--text-muted) p-2 hover:border-(--text-primary) hover:text-(--text-primary) transition-colors duration-300"
            aria-label="Repositorio GitHub"
          >
            <svg class="size-4" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
            </svg>
          </a>
        )}
      </div>
    </div>
  </div>

  <div class:list={["md:col-span-6 space-y-6", isEven ? "md:order-3" : "md:order-2"]}>

    <!-- Type + divider -->
    <div class="flex items-center gap-3">
      {type && (
        <span class="text-[9px] font-mono uppercase tracking-[0.35em] text-(--text-muted)">{type}</span>
      )}
      <div class="h-px flex-1 bg-(--border-subtle)/40"></div>
      {period && (
        <span class="text-[9px] font-mono text-(--text-muted)/50">{period}</span>
      )}
    </div>

    <h3 class="text-3xl md:text-4xl font-light tracking-tighter text-(--text-primary) leading-tight group-hover:translate-x-1 transition-transform duration-400">
      {title}
    </h3>

    <p class="text-sm md:text-base text-(--text-secondary) font-light leading-relaxed">
      {summary}
    </p>

    <div class="flex flex-wrap gap-x-5 gap-y-2 pt-2">
      {stack?.map((tech: string) => (
        <span class="text-[10px] font-mono uppercase tracking-[0.15em] text-(--text-muted) hover:text-(--text-primary) transition-colors">
          {tech}
        </span>
      ))}
    </div>

    <div class="flex items-center gap-6 pt-4">
      <a
        href={`/portafolio/projects/${slugify(title)}`}
        class="text-[11px] font-mono uppercase tracking-[0.3em] text-(--text-primary) underline-offset-4 hover:underline transition-all"
      >
        Leer más →
      </a>
      {github && (
        <a
          href={github}
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 text-[11px] font-mono uppercase tracking-[0.3em] text-(--text-muted) hover:text-(--text-primary) transition-colors"
        >
          <svg class="size-3.5" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
          </svg>
          Repositorio
        </a>
      )}
    </div>
  </div>

</article>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(20px);
    animation: fadeUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: var(--delay, 0ms);
  }

  @keyframes fadeUp {
    to { opacity: 1; transform: translateY(0); }
  }

  .image-wrap {
    filter: saturate(0.7);
    transition: filter 0.8s ease;
  }

  .project-row:hover .image-wrap {
    filter: saturate(1);
  }

  .project-img {
    transform: scale(1.04);
    transition: transform 1s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .project-row:hover .project-img {
    transform: scale(1);
  }
</style>