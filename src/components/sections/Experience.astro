---
import Section from "@layouts/Section.astro";
import cv from "../../cv.json"

const experiences = [
  {
    company: "Freelance Digital Solutions",
    role: "Desarrollador Frontend",
    period: "2025 — Presente",
    type: "Independiente",
    description:
      "Transformación digital de negocios locales mediante interfaces web de alto rendimiento. Cada proyecto busca elevar la presencia visual del cliente y convertir visitas en clientes reales.",
    highlights: [
      {
        title: "Arquitectura de Software",
        detail: "Experiencias ultra-rápidas con Astro y React. Optimización crítica para mobile.",
      },
      {
        title: "Rendimiento Visual",
        detail: "Sistemas de carga inteligente para portafolios en alta resolución sin penalizar el SEO.",
      },
      {
        title: "Conversión & UX",
        detail: "Integración de APIs de agendamiento y flujos de contacto minimalistas.",
      },
      {
        title: "Estrategia Digital",
        detail: "Consultoría técnica: desde arquitectura del servidor hasta posicionamiento local.",
      },
    ],
    tags: ["Core Web Vitals", "Local SEO", "UX Design", "Headless Tech"],
    clients: [
      { name: "BarberKing Studio", sector: "Barbería", location: "CDMX", year: "2025" },
      { name: "Atlas Gym", sector: "Fitness", location: "CDMX", year: "2025" },
      { name: "Fade & Style", sector: "Barbería", location: "CDMX", year: "2025" },
    ],
  },
];
---

<Section>
  <div class="mx-auto">

    <div class="flex items-center gap-6 mb-20">
      <span class="text-[10px] font-mono uppercase tracking-[0.5em] text-(--text-muted)">02 / Trayectoria</span>
      <div class="h-px flex-1 bg-(--border-subtle)/40"></div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">

      <div class="lg:col-span-3">
        <div class="lg:sticky lg:top-32 space-y-10">

          <div class="space-y-2">
            <p class="text-xs font-mono text-(--text-muted) uppercase tracking-widest">Perfil</p>
            <h2 class="text-lg font-light text-(--text-primary) leading-snug">{cv.basic.name}</h2>
            <p class="text-xs text-(--text-muted)">{cv.basic.label}</p>
          </div>

          <div class="h-px bg-(--border-subtle)/40 w-full"></div>

          <div class="space-y-3">
            <p class="text-[10px] font-mono uppercase tracking-[0.3em] text-(--text-muted)">Formación</p>
            {cv.education.map(edu => (
              <div class="space-y-1">
                <p class="text-xs text-(--text-primary) leading-snug">{edu.area}</p>
                <a href={edu.url} target="_blank" rel="noopener" class="text-[11px] text-(--text-muted) hover:text-(--text-secondary) transition-colors">
                  {edu.institution}
                </a>
                <p class="text-[10px] font-mono text-(--text-muted)/60">
                  {edu.startDate.slice(0, 4)} – {edu.endDate.slice(0, 4)}
                </p>
              </div>
            ))}
          </div>

          <div class="h-px bg-(--border-subtle)/40 w-full"></div>

          <!-- Tech Stack -->
          <div class="space-y-3">
            <p class="text-[10px] font-mono uppercase tracking-[0.3em] text-(--text-muted)">Stack</p>
            <div class="flex flex-wrap gap-2">
              {cv.skills.map(skill => (
                <span class="text-[10px] font-mono uppercase tracking-widest px-2 py-1 border border-(--border-subtle)/50 text-(--text-muted) hover:text-(--text-primary) hover:border-(--text-muted)/40 transition-all cursor-default">
                  {skill}
                </span>
              ))}
            </div>
          </div>

        </div>
      </div>

      <div class="lg:col-span-9 space-y-28">
        {experiences.map((exp, i) => (
          <article class="group">

            <!-- Role Header -->
            <div class="flex flex-col sm:flex-row justify-between items-start sm:items-end gap-4 mb-10 pb-10 border-b border-(--border-subtle)/40">
              <div class="space-y-2">
                <span class="text-[10px] font-mono uppercase tracking-widest text-(--text-muted)">{exp.company}</span>
                <h3 class="text-4xl md:text-5xl font-light tracking-tighter text-(--text-primary)">
                  {exp.role.split(" ").map((word, wi) =>
                    wi === 1
                      ? <span class="italic font-serif"> {word}</span>
                      : ` ${word}`
                  )}
                </h3>
              </div>
              <div class="text-right space-y-1">
                <p class="text-xs font-mono text-(--text-muted) uppercase tracking-widest">{exp.period}</p>
                <span class="text-[10px] font-mono text-(--text-muted)/50 uppercase">{exp.type}</span>
              </div>
            </div>

            <!-- Description -->
            <p class="text-xl md:text-2xl font-light leading-snug text-(--text-secondary) max-w-2xl mb-14">
              {exp.description}
            </p>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-px bg-(--border-subtle)/30 border border-(--border-subtle)/30 mb-14">
              {exp.highlights.map((h, hi) => (
                <div class="p-6 space-y-2 bg-(--bg-base) hover:bg-(--border-subtle)/10 transition-colors">
                  <div class="flex items-center gap-2 mb-3">
                    <span class="text-[10px] font-mono text-(--text-muted)/50">{String(hi + 1).padStart(2, "0")}</span>
                    <h4 class="text-[10px] font-mono uppercase tracking-[0.25em] text-(--text-primary)">{h.title}</h4>
                  </div>
                  <p class="text-[13px] text-(--text-secondary) leading-relaxed">{h.detail}</p>
                </div>
              ))}
            </div>

            <div class="space-y-4">
              <p class="text-[10px] font-mono uppercase tracking-[0.3em] text-(--text-muted) mb-6">Clientes</p>
              <div class="space-y-0 divide-y divide-(--border-subtle)/30">
                {exp.clients.map(client => (
                  <div class="flex items-center justify-between py-4 group/row hover:pl-2 transition-all duration-200">
                    <div class="flex items-center gap-6">
                      <span class="text-xs font-mono text-(--text-muted)/40 w-8">{client.year}</span>
                      <span class="text-sm text-(--text-primary)">{client.name}</span>
                    </div>
                    <div class="flex items-center gap-6">
                      <span class="text-[11px] font-mono text-(--text-muted) uppercase tracking-widest hidden sm:block">{client.sector}</span>
                      <span class="text-[10px] font-mono text-(--text-muted)/50">{client.location}</span>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <div class="flex flex-wrap gap-x-8 gap-y-3 pt-10 mt-10 border-t border-(--border-subtle)/30">
              {exp.tags.map(tag => (
                <span class="text-[10px] font-mono uppercase tracking-[0.2em] text-(--text-muted) hover:text-(--text-primary) transition-colors cursor-default">
                  {tag}
                </span>
              ))}
            </div>

          </article>
        ))}
      </div>

    </div>
  </div>
</Section>