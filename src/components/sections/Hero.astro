---
import cv from "../../cv.json";
import type { SocialProfile } from "@lib/types/social-profile";
import SocialLinks from "@components/ui/SocialLinks.astro";
import Section from "@layouts/Section.astro";

const { name, profiles, summary } = cv.basic;
const profilesData = profiles as SocialProfile[];

const myStack = ['React', 'Next.js', 'TypeScript', 'Python']
---

<Section id="sobremi" class="relative pt-10 md:pt-20 pb-16 overflow-hidden">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-y-12 lg:gap-16 items-start">

      <div class="lg:col-span-8 order-2 lg:order-1 flex flex-col space-y-10 text-center lg:text-left">

        <div class="flex items-center justify-center lg:justify-start gap-3">
          <div class="relative flex h-2 w-2">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-500 opacity-40"></span>
            <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
          </div>
          <span class="text-[10px] md:text-xs font-mono tracking-[0.3em] uppercase text-(--text-muted)">
            Disponible para trabajar
          </span>
        </div>

        <div class="space-y-6">
          <h1 class="text-6xl sm:text-7xl md:text-8xl lg:text-[10rem] font-bold tracking-tight text-(--text-primary) leading-[0.85]">
            {name.split(' ')[0]}<span class="text-(--accent-primary)">.</span>
          </h1>

          <div class="max-w-2xl mx-auto lg:mx-0">
            <h2 class="text-xl md:text-3xl font-light text-(--text-primary) leading-tight mb-4">
              Desarrollador Frontend
            </h2>
            <p class="text-sm md:text-lg text-(--text-muted) font-light leading-relaxed max-w-xl">
              {summary}
            </p>
          </div>
        </div>

        <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-8 pt-6 border-t border-(--border-subtle)/30">
          <SocialLinks profiles={profilesData} />

          <div class="hidden sm:block h-4 w-px bg-(--border-subtle)"></div>

          <div class="flex flex-wrap justify-center gap-6">
             {myStack.map(tech => (
               <span class="text-[10px] font-mono uppercase tracking-widest text-(--text-muted) hover:text-(--text-primary) transition-colors">
                 {tech}
               </span>
             ))}
          </div>
        </div>
      </div>

      <div class="lg:col-span-4 order-1 lg:order-2 flex justify-center lg:justify-end">
        <div class="relative group">
          <div class="absolute -top-4 -right-4 size-24 border-t border-r border-(--border-subtle) opacity-50"></div>
          <div class="absolute -bottom-4 -left-4 size-24 border-b border-l border-(--border-subtle) opacity-50"></div>

          <div class="relative size-48 sm:size-56 md:size-72 lg:size-80 overflow-hidden bg-(--bg-card) border border-(--border-subtle) grayscale hover:grayscale-0 transition-all duration-700 ease-in-out">
            <img
              src="/portafolio/images/me.jpeg"
              alt={name}
              class="w-full h-full object-cover object-top scale-100 group-hover:scale-110 transition-transform duration-1000"
            />
            <div class="absolute inset-0 bg-linear-to-t from-(--bg-main)/40 to-transparent"></div>
          </div>

          <div class="absolute -bottom-6 right-0 bg-(--bg-main) border border-(--border-subtle) px-4 py-2 shadow-xl">
            <p class="text-[9px] font-mono leading-none tracking-tighter text-(--text-primary)">
              <span class="font-bold">ESCOM</span> / IPN<br/>
              <span class="text-(--text-muted)">ENG GRADUATE</span>
            </p>
          </div>
        </div>
      </div>

    </div>
  </div>
</Section>
