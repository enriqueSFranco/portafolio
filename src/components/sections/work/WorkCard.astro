---
import Tag from "../../ui/Tag.astro"

interface Project {
  title: string;
  category: string;
  description: string;
  image: string;
  link: string;
}

interface Props {
  project: Project;
  idx: number;
}

const { project, idx }: Props = Astro.props;
---

<article
  class={`flex flex-col lg:flex-row gap-8 lg:gap-20 items-center reveal ${idx % 2 !== 0 ? "lg:flex-row-reverse" : ""}`}
>
  <div class="w-full lg:w-3/5 group">
    <a
      href={project.link}
      class="block relative aspect-video overflow-hidden rounded-xl border border-(--border-subtle)/30 shadow-2xl transition-all duration-500 group-hover:shadow-blue-600/10"
    >
      <picture>
        <img
          src={project.image}
          alt={project.title}
          class="w-full h-full object-cover object-center transition-transform duration-1000 group-hover:scale-105"
        />
      </picture>

      <div class="absolute inset-0 bg-linear-to-tr from-black/10 to-transparent opacity-40 group-hover:opacity-10 transition-opacity z-10"></div>
    </a>
  </div>

  <div class="w-full lg:w-2/5 space-y-8">
    <div class="space-y-2">
      <Tag variant="primary" label={project.category} />
      <h3 class="text-4xl md:text-5xl font-black tracking-tighter text-(--text-primary) leading-[0.9]">
        {project.title}
      </h3>
    </div>

    <p class="text-base md:text-lg text-(--text-secondary) leading-relaxed font-light max-w-sm">
      {project.description}
    </p>

    <a
      href={project.link}
      class="no-underline inline-flex items-center gap-3 group pb-1 transition-all hover:border-blue-600"
    >
      <span class="text-[11px] tracking-[0.2em] text-(--text-primary) group-hover:text-blue-600">
        Ver detalles
      </span>
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-right-icon lucide-arrow-right"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </a>
  </div>
</article>
