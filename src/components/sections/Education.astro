
---
import Section from "@layouts/Section.astro";
import cv from "../../cv.json";

const { education } = cv;

const highlights = [
  "Algoritmos & Estructuras de Datos",
  "Arquitectura de Software",
  "Bases de Datos",
  "Redes y Sistemas Distribuidos",
  "Fundamentos de UI/UX",
];

const formatYear = (date: string) => date.slice(0, 4);
---

<Section>

    <header class="flex items-center gap-6 mb-20">
      <span class="text-[10px] font-mono uppercase tracking-[0.5em] text-(--text-muted)">04 / Formación</span>
      <div class="h-px flex-1 bg-(--border-subtle)/40"></div>
    </header>

    {education.map((edu, i) => (
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 reveal" style={`--delay: ${i * 80}ms`}>

        <div class="lg:col-span-2 flex lg:flex-col lg:items-end gap-4 lg:gap-2 lg:pt-1">
          <span class="text-[10px] font-mono text-(--text-muted)/40 uppercase tracking-widest">
            {formatYear(edu.startDate)}
          </span>
          <div class="hidden lg:block h-full w-px bg-(--border-subtle)/30 ml-auto mr-0 min-h-4"></div>
          <span class="text-[10px] font-mono text-(--text-muted)/40 uppercase tracking-widest">
            {formatYear(edu.endDate)}
          </span>
        </div>

        <div class="lg:col-span-7 space-y-8 group relative pl-5 lg:pl-0 border-l lg:border-l-0 border-(--border-subtle)/30">

          <div class="hidden lg:block absolute -left-6 top-0 bottom-0 w-px bg-(--border-subtle)/20">
            <div class="w-full bg-(--text-primary) origin-top scale-y-0 group-hover:scale-y-100 transition-transform duration-700 h-full"></div>
          </div>

          <div class="space-y-2">
            <div class="flex items-center gap-3 mb-4">
              <span class="text-[9px] font-mono uppercase tracking-[0.4em] text-(--text-muted)">{edu.degree}</span>
              <div class="h-px flex-1 bg-(--border-subtle)/30"></div>
            </div>

            <h3 class="text-3xl md:text-4xl lg:text-5xl font-light tracking-tighter text-(--text-primary) leading-tight group-hover:translate-x-1 transition-transform duration-400">
              {edu.area}
            </h3>

            <a
              href={edu.url}
              target="_blank"
              rel="noopener"
              class="inline-flex items-center gap-2 text-sm text-(--text-muted) hover:text-(--text-primary) transition-colors mt-1"
            >
              <span>{edu.institution}</span>
              <svg class="size-3 opacity-50" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6M15 3h6v6M10 14 21 3"/>
              </svg>
            </a>
          </div>

          <p class="text-base text-(--text-secondary) font-light leading-relaxed max-w-lg">
            Formación técnica enfocada en la resolución de problemas de alta complejidad, algoritmos y diseño de sistemas.
            Desarrollo del proyecto de tesis: plataforma de bolsa de trabajo con sistema de recomendación inteligente para alumnos de ESCOM.
          </p>

          <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 pt-2">
            {highlights.map(item => (
              <div class="flex items-start gap-2 group/item">
                <span class="mt-[5px] w-1 h-1 rounded-full bg-(--border-subtle) shrink-0 group-hover/item:bg-(--text-primary) transition-colors"></span>
                <span class="text-[10px] font-mono uppercase tracking-[0.2em] text-(--text-muted) group-hover/item:text-(--text-primary) transition-colors leading-snug">
                  {item}
                </span>
              </div>
            ))}
          </div>

        </div>

        <div class="lg:col-span-3 space-y-6">

          <div class="border border-(--border-subtle)/40 p-5 space-y-5">

            <div class="space-y-1">
              <p class="text-[9px] font-mono uppercase tracking-[0.4em] text-(--text-muted)">Institución</p>
              <p class="text-xs text-(--text-primary) leading-snug">Instituto Politécnico Nacional</p>
            </div>

            <div class="h-px bg-(--border-subtle)/30"></div>

            <div class="space-y-1">
              <p class="text-[9px] font-mono uppercase tracking-[0.4em] text-(--text-muted)">Período</p>
              <p class="text-xs text-(--text-primary) font-mono">
                {formatYear(edu.startDate)} – {formatYear(edu.endDate)}
              </p>
            </div>

            <div class="h-px bg-(--border-subtle)/30"></div>

            <div class="space-y-1">
              <p class="text-[9px] font-mono uppercase tracking-[0.4em] text-(--text-muted)">Modalidad</p>
              <p class="text-xs text-(--text-primary)">Escolarizada · CDMX</p>
            </div>

            <div class="h-px bg-(--border-subtle)/30"></div>

            <div class="space-y-1">
              <p class="text-[9px] font-mono uppercase tracking-[0.4em] text-(--text-muted)">Proyecto final</p>
              <p class="text-xs text-(--text-secondary) leading-snug">Bolsa de Trabajo ESCOM con recomendación por habilidades</p>
            </div>

          </div>

        </div>

      </div>
    ))}

</Section>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(16px);
    animation: fadeUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: var(--delay, 0ms);
  }

  @keyframes fadeUp {
    to { opacity: 1; transform: translateY(0); }
  }
</style>
