---
import Section from "@layouts/Section.astro";
---

<Section id="educacion">
  <div class="max-w-5xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-8">

      <div class="md:col-span-3">
        <h2 class="text-xs font-mono uppercase tracking-[0.3em] text-(--text-muted) sticky top-24">
          Education / 03
        </h2>
      </div>

      <div class="md:col-span-9 space-y-12">
        <div class="group relative flex flex-col gap-4">
          <div class="flex flex-col md:flex-row justify-between items-baseline gap-2">
            <h3 class="text-2xl md:text-3xl font-medium tracking-tight text-(--text-primary) group-hover:text-(--accent-primary) transition-colors">
              Ingeniería en Sistemas Computacionales
            </h3>
            <span class="text-sm font-mono text-(--text-muted)">2017 — 2023</span>
          </div>

          <div class="space-y-6">
            <div class="flex items-center gap-2 text-(--text-secondary)">
              <span class="font-medium">ESCOM - Instituto Politécnico Nacional</span>
              <span class="text-(--border-subtle)">/</span>
              <span class="text-sm italic">Mexico City</span>
            </div>

            <p class="max-w-2xl text-(--text-secondary)/80 font-light leading-relaxed">
              Formación técnica enfocada en la resolución de problemas de alta complejidad, algoritmos y diseño de sistemas. Participación activa en proyectos de arquitectura de software y optimización.
            </p>

            <div class="flex flex-wrap gap-x-6 gap-y-2 pt-2">
              {["Distinction in Algorithms", "Software Architecture", "UI/UX Foundations"].map(item => (
                <div class="flex items-center gap-2">
                  <span class="w-1 h-1 bg-(--border-subtle) rounded-full"></span>
                  <span class="text-[10px] font-mono uppercase tracking-widest text-(--text-muted)">
                    {item}
                  </span>
                </div>
              ))}
            </div>
          </div>

          <div class="absolute -left-4 top-0 bottom-0 w-px bg-(--accent-primary) scale-y-0 group-hover:scale-y-100 transition-transform duration-500 origin-top"></div>
        </div>
      </div>

    </div>
  </div>
</Section>
