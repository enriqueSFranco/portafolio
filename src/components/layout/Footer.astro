---
import CopyButton from "@components/ui/CopyButton.astro";
import cv from "../../cv.json";

const { email, profiles, name } = cv.basic;
const currentYear = new Date().getFullYear();

const github = profiles.find(p => p.network === "github");
const linkedin = profiles.find(p => p.network === "linkedin");
---
<footer class="relative w-full pt-28 pb-12 border-t border-(--border-subtle)/40 overflow-hidden">

    <div class="flex flex-col gap-24">

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-y-12 lg:gap-x-10 items-end">

        <!-- Title -->
        <div class="lg:col-span-8 space-y-5 reveal" style="--delay:0ms">

          <p class="text-[10px] font-mono uppercase tracking-[0.45em] text-(--text-muted)">
            Siguiente paso
          </p>

          <h2 class="
            font-bold tracking-[-0.04em] leading-[0.9]
            text-[3.5rem]
            sm:text-[5rem]
            md:text-[7rem]
            lg:text-[9rem]
            xl:text-[10rem]
            text-(--text-primary)
          ">
            <a
              href={`mailto:${email}`}
              class="group relative inline-block"
            >
              <span class="relative z-10 transition-opacity duration-500 group-hover:opacity-60">
                Trabajemos
              </span>

              <span
                class="absolute bottom-2 left-0 h-[3px] w-0 bg-(--text-primary)
                group-hover:w-full transition-all duration-700 ease-out"
              ></span>
            </a>
          </h2>

        </div>

        <!-- Description -->
        <div class="lg:col-span-4 space-y-6 lg:pb-4 reveal" style="--delay:80ms">

          <p class="text-base font-light text-(--text-secondary) leading-relaxed max-w-sm lg:ml-auto lg:text-right">
            Abierto a proyectos, colaboraciones y retos que valga la pena construir.
          </p>

          <div class="lg:flex lg:justify-end">
            <a
              href={`mailto:${email}`}
              class="inline-flex items-center gap-3 border border-(--border-subtle)
              px-5 py-3 text-[10px] font-mono uppercase tracking-[0.3em]
              text-(--text-muted)
              hover:border-(--text-primary)
              hover:text-(--text-primary)
              transition-all duration-300"
            >

              <span class="relative flex h-1.5 w-1.5">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-500 opacity-60"></span>
                <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-green-500"></span>
              </span>

              Disponible ahora
            </a>
          </div>

        </div>

      </div>

      <!-- Info grid -->
      <div
        class="
        grid
        grid-cols-1
        sm:grid-cols-2
        lg:grid-cols-4
        gap-px
        bg-(--border-subtle)/30
        border border-(--border-subtle)/30
        reveal
        "
        style="--delay:160ms"
      >

        <!-- Card -->
        <div class="bg-(--bg-main) p-7 space-y-4 hover:bg-(--border-subtle)/10 transition-colors">
          <span class="text-[9px] font-mono uppercase tracking-[0.4em] text-(--text-muted)">Ubicación</span>
          <div>
            <p class="text-sm text-(--text-primary) font-light">CDMX, México</p>
            <p class="text-[10px] font-mono text-(--text-muted)/50 mt-1">UTC−6</p>
          </div>
        </div>

        <!-- Card -->
        <div class="bg-(--bg-main) p-7 space-y-4 hover:bg-(--border-subtle)/10 transition-colors">
          <span class="text-[9px] font-mono uppercase tracking-[0.4em] text-(--text-muted)">Email</span>
          <CopyButton label={email} text={email} variant="ghost" />
        </div>

        <!-- Card -->
        <div class="bg-(--bg-main) p-7 space-y-4 hover:bg-(--border-subtle)/10 transition-colors">
          <span class="text-[9px] font-mono uppercase tracking-[0.4em] text-(--text-muted)">Perfiles</span>

          <div class="flex flex-col gap-3">

            {linkedin && (
              <a
                href={linkedin.url}
                target="_blank"
                rel="noopener"
                class="inline-flex items-center gap-2 text-[11px] font-mono uppercase tracking-widest text-(--text-muted) hover:text-(--text-primary) transition-colors"
              >
                <svg class="size-3" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286z"/>
                </svg>
                LinkedIn
              </a>
            )}

            {github && (
              <a
                href={github.url}
                target="_blank"
                rel="noopener"
                class="inline-flex items-center gap-2 text-[11px] font-mono uppercase tracking-widest text-(--text-muted) hover:text-(--text-primary) transition-colors"
              >
                <svg class="size-3" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 .297c-6.63 0-12 5.373-12 12"/>
                </svg>
                GitHub
              </a>
            )}

          </div>
        </div>

        <!-- Card -->
        <div class="bg-(--bg-main) p-7 space-y-4 hover:bg-(--border-subtle)/10 transition-colors">

          <span class="text-[9px] font-mono uppercase tracking-[0.4em] text-(--text-muted)">Estado</span>

          <div>

            <div class="flex items-center gap-2">

              <span class="relative flex h-1.5 w-1.5">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-500 opacity-60"></span>
                <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-green-500"></span>
              </span>

              <p class="text-sm text-(--text-primary) font-light">
                Disponible
              </p>

            </div>

            <p class="text-[10px] font-mono text-(--text-muted)/50 mt-1">
              Freelance · Remoto
            </p>

          </div>

        </div>

      </div>

      <!-- Bottom -->
      <div
        class="flex flex-col md:flex-row justify-between items-start md:items-center gap-8 pt-4 border-t border-(--border-subtle)/20 reveal"
        style="--delay:240ms"
      >

        <p class="text-[9px] font-mono uppercase tracking-[0.3em] text-(--text-muted)/40">
          © {currentYear} — {name}
        </p>

        <div class="flex flex-wrap gap-x-6 gap-y-2 text-[9px] font-mono uppercase tracking-[0.25em] text-(--text-muted)/30">
          <span>Astro 5</span>
          <span>·</span>
          <span>Tailwind CSS</span>
          <span>·</span>
          <span>TypeScript</span>
          <span>·</span>
          <span>Diseñado en CDMX</span>
        </div>

      </div>

    </div>
</footer>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(14px);
    animation: fadeUp 0.7s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    animation-delay: var(--delay, 0ms);
  }

  @keyframes fadeUp {
    to { opacity: 1; transform: translateY(0); }
  }
</style>
