---
import cv from "../../cv.json";

const { name, email, profiles } = cv.basic;
const currentYear = new Date().getFullYear();

const linkedin = profiles.find(p => p.network === "LinkedIn");
const github = profiles.find(p => p.network === "GitHub");
---

<footer class="relative w-full pt-24 pb-12 px-6 bg-gray-50 overflow-hidden" role="contentinfo">
  <div class="max-w-7xl mx-auto space-y-20 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-end">
      <div class="lg:col-span-8 space-y-8 reveal" style="--delay: 100ms">
        <h2 class="text-4xl md:text-7xl font-black tracking-tighter text-(--text-primary) leading-none">
          ¿Listo para <br />
          <span class="text-blue-600">escalar tu negocio?</span>
        </h2>
        <p class="max-w-xl text-lg text-(--text-secondary) font-light leading-relaxed">
          Sistemas diseñados para que tu negocio no se detenga. Conectemos para transformar tus procesos manuales en flujos digitales eficientes.
        </p>
      </div>

      <div class="lg:col-span-4 flex flex-col gap-4 reveal" style="--delay: 200ms">
        <a href="https://wa.me/tu-numero-aqui"
           class="group flex items-center justify-between p-6 bg-blue-600 text-white hover:bg-neutral-900 transition-all shadow-xl shadow-blue-900/10">
          <span class="text-xs font-bold uppercase tracking-[0.3em]">Hablar por WhatsApp</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="size-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
        <a href={`mailto:${email}`}
           class="p-6 border-2 border-neutral-900 text-neutral-900 text-xs font-bold uppercase tracking-[0.3em] hover:bg-neutral-900 hover:text-white transition-all text-center">
          Enviar Correo
        </a>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-12 gap-12 pt-16 reveal" style="--delay: 300ms">

      <div class="md:col-span-4 space-y-4">
        <div class="flex flex-col">
          <span class="text-[10px] font-bold text-blue-600 uppercase tracking-[0.4em] mb-1">Ingeniero en Sistemas</span>
          <span class="text-xl font-black tracking-tighter text-(--text-primary)">{name}</span>
        </div>
        <p class="text-xs text-(--text-muted) leading-relaxed max-w-[240px]">
          Construyendo herramientas digitales que optimizan procesos y proyectan la solidez de tu negocio.
        </p>
      </div>

      <div class="md:col-span-2 space-y-4">
        <p class="text-[9px] font-bold uppercase tracking-[0.3em] text-gray-500">Navegación</p>
        <ul class="space-y-2">
          <li><a href="/portafolio/trabajos" class="text-xs text-(--text-secondary) hover:text-blue-600 transition-colors">Proyectos</a></li>
          <li><a href="/portafolio/conoceme" class="text-xs text-(--text-secondary) hover:text-blue-600 transition-colors">Metodología</a></li>
          <li><a href="#servicios" class="text-xs text-(--text-secondary) hover:text-blue-600 transition-colors">Servicios</a></li>
        </ul>
      </div>

      <div class="md:col-span-2 space-y-4">
        <p class="text-[9px] font-bold uppercase tracking-[0.3em] text-gray-500">Conecta</p>
        <ul class="space-y-2">
          {linkedin && <li><a href={linkedin.url} class="text-xs text-(--text-secondary) hover:text-blue-600 transition-colors">LinkedIn</a></li>}
          {github && <li><a href={github.url} class="text-xs text-(--text-secondary) hover:text-blue-600 transition-colors">GitHub</a></li>}
        </ul>
      </div>

      <div class="md:col-span-4 flex flex-col justify-end items-start md:items-end space-y-2">
        <span class="text-[10px] font-mono text-(--text-muted)">
          &copy; {currentYear} {name} Studio.
        </span>
        <span class="text-[9px] font-mono text-neutral-400 uppercase tracking-widest">
          ESCOM · IPN
        </span>
      </div>
    </div>
  </div>

  <div class="absolute -bottom-20 -right-20 text-[20vw] font-black bg-linear-to-b from-gray-700/10 to-gray-50 bg-clip-text text-transparent select-none pointer-events-none uppercase tracking-tighter" aria-hidden="true">
    SYSTEMS
  </div>
</footer>
