---
const navLinks = [
{ id: "trabajos", label: "Trabajos", href: "/portafolio/trabajos" },
  { id: "clientes",  label: "Clientes",  href: "/portafolio/clientes"  },
  { id: "conoceme",  label: "Conóceme",  href: "/portafolio/conoceme"  },
  { id: "contacto",  label: "Contacto",  href: "/portafolio/contacto"  }
]

// detectar ruta actual
const currentPath = Astro.url.pathname

function isActive(href: string) {
  return currentPath === href || currentPath.startsWith(href + "/");
}
---

<header
  class="header-site sticky top-0 z-50 w-full transition-all duration-500" role="banner"
  role="banner"
>
  <div class="header-container mx-auto max-w-6xl px-5 sm:px-8 lg:px-10 flex items-center justify-between h-16 sm:h-20">
    <!-- Logo / Brand -->
    <a
  href="/portafolio"
  aria-label="Enrique Salinas Franco — Ir al inicio"
  class="group flex items-center gap-3 shrink-0 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-blue-600 rounded-lg p-1 transition-transform active:scale-95"
>
  <div class="flex flex-col leading-none">
    <span class="text-sm font-black tracking-tighter text-neutral-900 uppercase">
      Enrique <span class="text-blue-600 ml-1">S</span> Franco
    </span>
    <span class="text-[9px] font-mono font-bold tracking-[0.2em] text-neutral-400 uppercase mt-1">
      Ingeniero en sistemas
    </span>
  </div>

  <div class="h-8 w-px bg-neutral-200 group-hover:bg-blue-600/30 transition-colors"></div>

  <div class="flex flex-col justify-center gap-1.5 leading-[0.8] tracking-wide">
    <span class="text-[10px] font-black text-neutral-900 uppercase">Full</span>
    <span class="text-[10px] font-black text-neutral-400 uppercase">Stack Developer</span>
  </div>
</a>

    <!-- ── Nav Desktop ── -->
    <nav aria-label="Navegación principal" class="hidden md:block">
      <ul class="flex items-center gap-1" role="list">
        {navLinks.map((link) => {
          const active = isActive(link.href);
          return (
            <li>
              <a
                href={link.href}
                aria-current={active ? "page" : undefined}
                class:list={[
                  "relative px-3.5 py-2 rounded-lg text-sm font-medium",
                  "transition-colors duration-150",
                  "focus-visible:outline-none focus-visible:ring-2",
                  "focus-visible:ring-black dark:focus-visible:ring-white focus-visible:ring-offset-1",
                  // Estado activo
                  active
                    ? "text-black dark:text-white bg-black/5 dark:bg-white/5"
                    : "text-neutral-500 dark:text-neutral-700 hover:text-black dark:hover:text-white hover:bg-black/5 dark:hover:bg-white/5",
                ]}
              >
                {link.label}
                {active && (
                  <span
                    aria-hidden="true"
                    class="absolute bottom-1 left-1/2 -translate-x-1/2
                           w-3 h-0.5 rounded-full bg-black dark:bg-white"
                  />
                )}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>

    <div class="flex items-center gap-3 sm:gap-4 shrink-0">
      <div
        role="status"
        aria-label="Estado: disponible para proyectos"
        class="hidden sm:flex items-center gap-1.5 text-xs tracking-wide text-neutral-500 dark:text-neutral-400"
      >
        <span class="relative flex h-1.5 w-1.5" aria-hidden="true">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-500 opacity-50" />
          <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-emerald-500" />
        </span>
        <span>Disponible</span>
      </div>

      <!-- ── Mobile Menu ── -->
      <details class="md:hidden relative" id="mobile-menu">
        <summary
          aria-label="Abrir menú de navegación"
          class="list-none cursor-pointer grid place-content-center w-9 h-9 rounded-lg text-neutral-600 dark:text-neutral-300 hover:bg-black/5 dark:hover:bg-white/[0.07] focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-black dark:focus-visible:ring-white transition-colors duration-150"
        >
          <!-- Ícono hamburger / close via CSS — sin JS -->
          <span aria-hidden="true" class="hamburger-icon">
            <span></span>
            <span></span>
            <span></span>
          </span>
        </summary>

        <nav
          aria-label="Navegación móvil"
          class="absolute right-0 top-[calc(100%+0.5rem)] w-56 bg-white dark:bg-neutral-900 border border-black/5 dark:border-white/5 rounded-2xl shadow-xl shadow-black/10 dark:shadow-black/30 overflow-hidden animate-menu-in"
        >
          <!-- Status en mobile (dentro del menú) -->
          <div class="flex items-center gap-2 px-4 py-3 border-b border-white/5 dark:border-white/5">
            <span class="relative flex h-1.5 w-1.5" aria-hidden="true">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-500 opacity-50" />
              <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-emerald-500" />
            </span>
            <span class="text-xs text-neutral-400 dark:text-neutral-500 tracking-wide">
              Disponible para proyectos
            </span>
          </div>

          <ul class="py-1.5" role="list">
            {navLinks.map((link) => {
              const active = isActive(link.href);
              return (
                <li>
                  <a
                    href={link.href}
                    aria-current={active ? "page" : undefined}
                    class:list={[
                      "mobile-nav-link",
                      "flex items-center justify-between",
                      "px-4 py-2.5 text-sm font-medium",
                      "transition-colors duration-100",
                      "focus-visible:outline-none focus-visible:bg-black/5 dark:focus-visible:bg-white/5",
                      active
                        ? "text-black dark:text-white bg-black/5 dark:bg-white/5"
                        : "text-neutral-600 dark:text-neutral-300 hover:text-black dark:hover:text-white hover:bg-black/5 dark:hover:bg-white/5",
                    ]}
                  >
                    {link.label}
                    {active && (
                      <span aria-hidden="true"
                        class="w-1.5 h-1.5 rounded-full bg-black dark:bg-white" />
                    )}
                  </a>
                </li>
              );
            })}
          </ul>
        </nav>
      </details>
    </div>
  </div>
</header>

<style>
  @media (min-width: 360px) {
    .xs\:block { display: block; }
  }

  .hamburger-icon {
    display: flex;
    flex-direction: column;
    gap: 4px;
    width: 18px;
  }

  .hamburger-icon span {
    display: block;
    height: 1.5px;
    border-radius: 9999px;
    background-color: currentColor;
    transition: transform 0.2s ease, opacity 0.2s ease, width 0.2s ease;
    transform-origin: center;
  }

  .hamburger-icon span:last-child {
    width: 12px;
  }

  details[open] .hamburger-icon span:nth-child(1) {
    transform: translateY(5.5px) rotate(45deg);
  }
  details[open] .hamburger-icon span:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }
  details[open] .hamburger-icon span:nth-child(3) {
    width: 18px;
    transform: translateY(-5.5px) rotate(-45deg);
  }

  summary::-webkit-details-marker { display: none; }
  summary::marker { display: none; }

  .header-container {
    height: 80px;
    transition: height 0.3s ease;
  }

  header {
    background-color: rgba(255, 255, 255, 0);
    backdrop-filter: blur(0px);
    border-bottom: 1px solid transparent;

    animation: scroll-reveal linear both;
    animation-timeline: scroll();
    animation-range: 0 100px;
  }

  @keyframes scroll-reveal {
    to {
      background-color: rgba(255, 255, 255, 0.8);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid rgba(0, 0, 0, 0.1);
    }
  }

  .header-container {
    animation: scroll-height linear both;
    animation-timeline: scroll();
    animation-range: 0 100px;
  }

  @keyframes scroll-height {
    to {
      height: 60px; /* Altura final compacta */
    }
  }

  @media (prefers-color-scheme: dark) {
    @keyframes header-scroll {
      to {
        background-color: rgba(10, 10, 10, 0.7);
        backdrop-filter: blur(12px);
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        height: 70px;
      }
    }
  }

  @keyframes menuIn {
    from {
      opacity: 0;
      transform: translateY(-6px) scale(0.97);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }
  .animate-menu-in {
    animation: menuIn 0.18s ease-out both;
  }
</style>
