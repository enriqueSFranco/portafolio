---
import { render } from "astro:content";
import { getAllProjects } from "@lib/projects";
import Layout from "@layouts/Layout.astro";
import Section from "@layouts/Section.astro";
import Prose from "@components/layout/Prose.astro";
import { slugify } from "@lib/utils";

export const getStaticPaths = async () => {
  const projects = await getAllProjects();
  return projects.map((project) => ({
    params: { slug: slugify(project.data.title) },
    props: { project },
  }));
};

const { project } = Astro.props;
const { data } = project;
const { title, cover, summary, stack, github, year, type, status } = data;
const { Content } = await render(project);
---

<Layout title={`${title} | Caso de Estudio`}>

  <!-- Reading progress bar -->
  <div id="progress-bar" class="fixed top-0 left-0 h-[2px] bg-(--text-primary) z-50 w-0 transition-none origin-left"></div>

  <!-- Back nav -->
  <div class="max-w-7xl mx-auto px-6 pt-10">
    <a
      href="/portafolio/"
      class="group inline-flex items-center gap-3 text-(--text-muted) hover:text-(--text-primary) transition-colors text-[10px] font-mono tracking-[0.35em] uppercase"
    >
      <svg class="size-3 transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 19l-7-7 7-7"/>
      </svg>
      Todos los proyectos
    </a>
  </div>

  <!-- ── HERO ─────────────────────────────────────── -->
  <Section>
    <div class="max-w-7xl mx-auto px-6 space-y-16">

      <!-- Title block -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-end pt-6">

        <div class="lg:col-span-8 space-y-6">
          <div class="flex items-center gap-4">
            <span class="text-[10px] font-mono uppercase tracking-[0.45em] text-(--text-muted)">
              Caso de estudio
            </span>
            {year && (
              <span class="text-[10px] font-mono text-(--text-muted)/40">— {year}</span>
            )}
            {status && (
              <span class="text-[9px] font-mono uppercase tracking-widest border border-(--border-subtle) px-2 py-0.5 text-(--text-muted)">
                {status}
              </span>
            )}
          </div>

          <h1 class="text-[14vw] lg:text-[9rem] font-bold tracking-[-0.04em] leading-[0.85] text-(--text-primary)">
            {title}
          </h1>

          <p class="text-xl md:text-2xl font-light text-(--text-secondary) leading-relaxed max-w-2xl">
            {summary}
          </p>
        </div>

        <!-- CTA column -->
        <div class="lg:col-span-4 space-y-4 lg:pb-3">
          {github && (
            <div class="flex flex-col gap-3">
              <a
                href={github}
                target="_blank"
                rel="noopener"
                class="inline-flex items-center justify-between gap-4 border border-(--text-primary) px-5 py-3.5 text-[10px] font-mono uppercase tracking-[0.3em] text-(--text-primary) hover:bg-(--text-primary) hover:text-(--bg-main) transition-all duration-300 group"
              >
                Ver repositorio
                <svg class="size-3 transition-transform group-hover:translate-x-1 group-hover:-translate-y-1" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path d="M7 17L17 7M17 7H7M17 7v10"/>
                </svg>
              </a>
              <a
                href={github}
                target="_blank"
                rel="noopener"
                class="inline-flex items-center justify-between gap-4 border border-(--border-subtle) px-5 py-3.5 text-[10px] font-mono uppercase tracking-[0.3em] text-(--text-muted) hover:border-(--text-primary) hover:text-(--text-primary) transition-all duration-300 group"
              >
                Demo en vivo
                <svg class="size-3 transition-transform group-hover:translate-x-1 group-hover:-translate-y-1" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                  <path d="M7 17L17 7M17 7H7M17 7v10"/>
                </svg>
              </a>
            </div>
          )}
        </div>
      </div>

      <!-- Meta strip -->
      <div class="grid grid-cols-2 md:grid-cols-4 gap-px bg-(--border-subtle)/30 border border-(--border-subtle)/30">
        <div class="bg-(--bg-main) p-5 space-y-2 hover:bg-(--border-subtle)/10 transition-colors">
          <span class="text-[9px] font-mono uppercase tracking-[0.4em] text-(--text-muted)">Stack</span>
          <div class="flex flex-wrap gap-x-3 gap-y-1">
            {stack?.map((item: string) => (
              <span class="text-[11px] font-mono text-(--text-primary)">{item}</span>
            ))}
          </div>
        </div>
        <div class="bg-(--bg-main) p-5 space-y-2 hover:bg-(--border-subtle)/10 transition-colors">
          <span class="text-[9px] font-mono uppercase tracking-[0.4em] text-(--text-muted)">Tipo</span>
          <p class="text-xs text-(--text-primary) font-light">{type ?? "Proyecto Personal"}</p>
        </div>
        <div class="bg-(--bg-main) p-5 space-y-2 hover:bg-(--border-subtle)/10 transition-colors">
          <span class="text-[9px] font-mono uppercase tracking-[0.4em] text-(--text-muted)">Rol</span>
          <p class="text-xs text-(--text-primary) font-light">Diseño & Desarrollo</p>
        </div>
        <div class="bg-(--bg-main) p-5 space-y-2 hover:bg-(--border-subtle)/10 transition-colors">
          <span class="text-[9px] font-mono uppercase tracking-[0.4em] text-(--text-muted)">Origen</span>
          <p class="text-xs text-(--text-primary) font-light">México · CDMX</p>
        </div>
      </div>

      <!-- Cover image -->
      <div class="relative w-full aspect-video md:aspect-[21/9] overflow-hidden bg-(--bg-card) border border-(--border-subtle)/40">
        {cover ? (
          <>
            <img
              transition:name={`img-${title}`}
              src={cover}
              alt={title}
              class="w-full h-full object-cover cover-img"
              loading="eager"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-(--bg-main)/30 to-transparent pointer-events-none"></div>
          </>
        ) : (
          <div class="grid h-full place-content-center">
            <span class="text-[10px] font-mono uppercase tracking-widest text-(--text-muted)/30">{title}</span>
          </div>
        )}
      </div>

    </div>
  </Section>

  <!-- ── CONTENT ────────────────────────────────── -->
  <div class="max-w-7xl mx-auto px-6 pb-32">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">

      <!-- Main prose -->
      <div class="lg:col-span-7 lg:col-start-1">
        <Prose>
          <Content />
        </Prose>
      </div>

      <!-- Sticky sidebar -->
      <aside class="hidden lg:flex lg:col-span-4 lg:col-start-9 flex-col gap-10 sticky top-28 h-fit">

        <!-- Deliverables -->
        <div class="border border-(--border-subtle)/40 p-6 space-y-5">
          <p class="text-[9px] font-mono uppercase tracking-[0.4em] text-(--text-muted)">Entregables</p>
          <ul class="space-y-3">
            {[
              "Auditoría de rendimiento",
              "Estrategia SEO local",
              "Sistema de diseño UI",
              "Despliegue en producción",
            ].map((item, i) => (
              <li class="flex items-start gap-3">
                <span class="text-[9px] font-mono text-(--text-muted)/30 mt-0.5 tabular-nums">{String(i + 1).padStart(2, "0")}</span>
                <span class="text-xs text-(--text-secondary) font-light">{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Stack repeat -->
        <div class="border border-(--border-subtle)/40 p-6 space-y-5">
          <p class="text-[9px] font-mono uppercase tracking-[0.4em] text-(--text-muted)">Tecnologías</p>
          <div class="flex flex-wrap gap-2">
            {stack?.map((item: string) => (
              <span class="text-[10px] font-mono uppercase tracking-widest px-2 py-1 border border-(--border-subtle)/50 text-(--text-muted) hover:text-(--text-primary) hover:border-(--text-muted)/40 transition-all cursor-default">
                {item}
              </span>
            ))}
          </div>
        </div>

        <!-- CTA -->
        <div class="border border-(--border-subtle)/40 p-6 space-y-4">
          <p class="text-[9px] font-mono uppercase tracking-[0.4em] text-(--text-muted)">¿Proyecto similar?</p>
          <p class="text-xs text-(--text-secondary) font-light leading-relaxed">
            Si tienes un negocio y quieres algo parecido, hablemos.
          </p>
          <a
            href="mailto:enrique.sfranco04@gmail.com"
            class="flex items-center justify-between text-[10px] font-mono uppercase tracking-[0.25em] text-(--text-primary) hover:opacity-60 transition-opacity pt-1"
          >
            Contactar
            <svg class="size-3" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
              <path d="M7 17L17 7M17 7H7M17 7v10"/>
            </svg>
          </a>
        </div>

      </aside>
    </div>
  </div>

</Layout>

<style>
  .cover-img {
    filter: grayscale(60%);
    transform: scale(1.04);
    transition: filter 1.2s ease, transform 1.2s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .cover-img:hover {
    filter: grayscale(0%);
    transform: scale(1);
  }
</style>

<script>
  const bar = document.getElementById("progress-bar");

  const update = () => {
    const scrollTop = window.scrollY;
    const docHeight = document.documentElement.scrollHeight - window.innerHeight;
    const pct = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
    if (bar) bar.style.width = `${pct}%`;
  };

  window.addEventListener("scroll", update, { passive: true });
  update();
</script>
