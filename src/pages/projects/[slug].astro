---
import { render } from "astro:content";
import { getAllProjects } from "@lib/projects";
import Layout from "@layouts/Layout.astro";
import Section from "@layouts/Section.astro";
import Prose from "@components/layout/Prose.astro";
import { slugify } from "@lib/utils";

export const getStaticPaths = async () => {
  const projects = await getAllProjects();

  return projects.map((project) => {
    const slug = slugify(project.data.title);

    return {
      params: { slug },
      props: { project },
    };
  });
};
const { project } = Astro.props;
const { data } = project;
const { title, cover, summary, stack, github, year } = data;
const { Content } = await render(project);
---

<Layout title={`${title} | Case Study`}>
  <div id="progress-bar" class="fixed top-0 left-0 h-1 bg-(--accent-primary) z-50 transition-all duration-150 w-0"></div>

  <div class="max-w-5xl mx-auto px-6 pt-12">
    <a
      href="/portafolio/"
      class="group inline-flex items-center gap-2 text-(--text-muted) hover:text-(--text-primary) transition-colors text-[10px] font-mono tracking-widest uppercase"
    >
      <svg class="size-3 transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Volver al inicio
    </a>
  </div>

  <Section id="project-hero" class="pt-8 pb-20">
    <div class="space-y-16">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">
        <div class="lg:col-span-8 space-y-8">
          <div class="space-y-4">
             <span class="text-(--accent-primary) font-mono text-xs uppercase tracking-[0.3em]">Caso de Estudio / {year}</span>
             <h1 class="text-6xl md:text-8xl lg:text-9xl font-bold tracking-tight text-(--text-primary) leading-[0.85]">
               {title}<span class="text-(--accent-primary)">.</span>
             </h1>
          </div>
          <p class="text-xl md:text-2xl font-light text-(--text-secondary) leading-relaxed max-w-3xl italic font-serif">
            {summary}
          </p>
        </div>

        <div class="lg:col-span-4 flex flex-col lg:items-end justify-between h-full py-2">
           <div class="flex flex-wrap lg:justify-end gap-3">
            {github && (
                <a href={github} target="_blank" class="px-6 py-3 rounded-full border border-(--border-subtle) text-[10px] font-mono uppercase tracking-widest hover:border-(--text-primary) transition-all">
                  Source Code
                </a>
            )}
            {github && (
                <a href={github} target="_blank" class="px-6 py-3 rounded-full bg-(--text-primary) text-(--bg-main) text-[10px] font-mono uppercase tracking-widest font-bold hover:bg-(--accent-primary) transition-all">
                  Ver Proyecto
                </a>
            )}
           </div>
        </div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-4 border-y border-(--border-subtle)/30 py-10 font-mono text-[10px] uppercase tracking-[0.2em] gap-8">
        <div class="space-y-3">
          <span class="text-(--text-muted) block">Stack Tecnológico</span>
          <div class="flex flex-wrap gap-2">
            {stack?.map((item: string) => (
              <span class="text-(--text-primary)">{item}</span>
            ))}
          </div>
        </div>
        <div class="space-y-3">
          <span class="text-(--text-muted) block">Cliente / Negocio</span>
          <p class="text-(--text-primary)">Local Business</p>
        </div>
        <div class="space-y-3">
          <span class="text-(--text-muted) block">Rol</span>
          <p class="text-(--text-primary)">Ingeniero de Producto</p>
        </div>
        <div class="space-y-3 md:text-right">
          <span class="text-(--text-muted) block">Localización</span>
          <p class="text-(--text-primary)">México, CDMX</p>
        </div>
      </div>

      <div class="relative w-full aspect-video md:aspect-21/9 overflow-hidden rounded-sm border border-(--border-subtle)/50 bg-(--bg-card)">
        <img
          transition:name={`img-${title}`}
          src={cover}
          alt={title}
          class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-1000 scale-105"
        />
        <div class="absolute inset-0 bg-linear-to-t from-(--bg-main)/20 to-transparent"></div>
      </div>
    </div>
  </Section>

  <div class="relative max-w-5xl mx-auto px-6 pb-32">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
      <div class="lg:col-span-8 lg:col-start-1 prose-content">
        <Prose>
          <Content />
        </Prose>
      </div>

      <aside class="hidden lg:block lg:col-span-3 lg:col-start-10 sticky top-32 h-fit space-y-12">
        <div class="space-y-4">
          <h4 class="text-[10px] font-mono uppercase tracking-widest text-(--accent-primary)">Entregables</h4>
          <ul class="text-xs space-y-2 text-(--text-secondary) font-light">
            <li>— Auditoría de Rendimiento</li>
            <li>— Estrategia SEO Local</li>
            <li>— UI Design System</li>
            <li>— Despliegue en Producción</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</Layout>
