---
import { ClientRouter } from "astro:transitions";

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width" />
  <title>{title}</title>

  <link rel="icon" type="image/svg+xml" href="/logo.svg" />

  <meta name="description" content="Diseño sistemas que trabajan por ti. Ingeniería de software a medida para optimizar procesos y escalar negocios." />
  <meta name="author" content="Enrique SFranco" />

  <meta property="og:type" content="website" />
  <meta property="og:url" content={Astro.url} />
  <meta property="og:title" content="Enrique SFranco | Ingeniero en Sistemas Computacionales" />
  <meta property="og:description" content="Ingeniería pensada para elevar el estándar local. Soluciones digitales sólidas y escalables." />
  <meta property="og:image" content="https://enriquesfranco.github.io/portafolio/og-image.jpg" />
  <meta property="og:locale" content="es_MX" />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Enrique SFranco | Ingeniero en Sistemas Computacionales" />
  <meta name="twitter:description" content="Diseño sistemas que trabajan por ti. Ingeniería de software a medida para optimizar procesos y escalar negocios." />
  <meta name="twitter:image" content="https://enriquesfranco.github.io/portafolio/og-image.jpg" />

  <ClientRouter />
</head>
